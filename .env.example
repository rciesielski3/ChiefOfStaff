# PAIOS Environment Configuration Template
# Copy this file to .env and populate with your actual values
# DO NOT commit .env to git (add to .gitignore)
# For detailed instructions, see docs/ENVIRONMENT_SETUP.md

################################################################################
# n8n Configuration
################################################################################

# Random 32-character string for encrypting n8n data
# Generate with: openssl rand -base64 24
N8N_ENCRYPTION_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Random 32-character string for JWT secrets
N8N_USER_MANAGEMENT_JWT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# n8n Server Configuration (local development)
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_BASIC_AUTH_ACTIVE=false
N8N_API_GATEWAY_AUTH=none
N8N_ENABLE_AUTHORIZATION=false

# Environment
NODE_ENV=development
GENERIC_TIMEZONE=UTC

################################################################################
# Database Configuration
################################################################################

# Choose one of the following database setups:

# Option 1: PostgreSQL (recommended for production/VPS)
N8N_DB_TYPE=postgres
N8N_DB_HOST=postgres
N8N_DB_PORT=5432
N8N_DB_NAME=paios
N8N_DB_USER=paios
N8N_DB_PASSWORD=your_secure_postgres_password

# PostgreSQL credentials (if using separate DB container)
POSTGRES_USER=paios
POSTGRES_PASSWORD=your_secure_postgres_password
POSTGRES_DB=paios
POSTGRES_HOST=postgres

# Option 2: SQLite (default for local development, simpler setup)
# Leave N8N_DB_* variables unset or commented to use SQLite

# Alternative: Direct PostgreSQL connection URL
# DATABASE_URL=postgresql://paios:password@localhost:5432/paios

################################################################################
# Telegram Integration
################################################################################

# Your Telegram Bot Token from @BotFather
# Get this by creating a bot with @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCDefGhIjKlMnOpQrStUvWxYzAbCdEf

# Your Telegram Chat ID where bot sends messages
# Get this by sending any message to your bot and calling getUpdates
TELEGRAM_CHAT_ID=987654321

################################################################################
# OpenAI API Configuration
################################################################################

# OpenAI API Key for LLM features (article scoring, summarization)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

################################################################################
# PAIOS Vault & Export Configuration
################################################################################

# Local path to paios-vault repository (git-backed document storage)
# Local development: ~/paios-vault or /path/to/paios-vault
# VPS deployment: /opt/paios-vault
PAIOS_VAULT_PATH=/path/to/paios-vault

# Path where export-latest-news workflow writes latest.json
# Local development: qa-news/public/latest.json
# VPS deployment: /opt/paios/qa-news/public/latest.json
EXPORT_FILE_PATH=/path/to/qa-news/public/latest.json

# Git repository URL for vault sync (optional, for automated commits)
VAULT_GIT_REPO=https://github.com/your-org/paios-vault.git

# Git credentials for vault sync
VAULT_GIT_USERNAME=your_github_username
VAULT_GIT_TOKEN=your_github_personal_access_token

################################################################################
# Restic Backup Configuration (VPS deployment)
################################################################################

# Password for Restic backup encryption
# Generate with: openssl rand -base64 32
RESTIC_PASSWORD=your_backup_encryption_password

# Restic repository location
# Local: /backup/restic-repo (must be on persistent volume)
# S3: s3://s3.amazonaws.com/bucket-name/paios
RESTIC_REPOSITORY=/backup/restic-repo

################################################################################
# AWS S3 Configuration (for remote backups via Restic)
################################################################################

# AWS credentials for S3 backups
# Only required if using RESTIC_REPOSITORY=s3://...
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# Alternative S3 endpoint (for S3-compatible services)
# AWS_S3_ENDPOINT=https://s3.example.com

################################################################################
# Tailscale Configuration (VPS only)
################################################################################

# Tailscale Auth Key for secure VPS access
# Get from: https://login.tailscale.com/admin/settings/keys
# Only required for VPS deployment
TAILSCALE_AUTH_KEY=tskey-auth-xxxxxxxxxxxxxxxxxxxxxxx

################################################################################
# Domain Configuration
################################################################################

# Your domain name for the deployed application
# Used for DNS configuration and external access
PAIOS_DOMAIN=paios.example.com

################################################################################
# QA News Frontend Configuration
################################################################################

# URL to PAIOS latest.json export (for QA News frontend)
# Local: http://localhost:5678/api/latest (or file path)
# Production: https://paios.example.com/api/latest
PAIOS_LATEST_JSON_URL=http://localhost:5678/api/latest

# PAIOS Public API endpoint for curated content
# Local: http://localhost:5678/api
# Production: https://paios.example.com/api
PAIOS_API_URL=http://localhost:5678/api

################################################################################
# Docker Compose Overrides (optional)
################################################################################

# Current working directory path for volume mounts
# Usually set automatically by docker-compose
# PWD=/path/to/paios
